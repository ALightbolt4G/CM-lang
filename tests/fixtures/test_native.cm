// test_native.cm - Test native API features

require("public_html/");

// Native str type (alias for string)
str name = input();
name.upper();

// Native malloc/free
ptr data = malloc(1024);
gc_collect();
free(data);

// Print and GC
print("Hello, ");
print(name);
print("!\n");
gc_collect();

// HTTP server
c {
    cm_app_get("/", cm_serve_index);
    cm_app_listen(8080);
}
