{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CM",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.cm", "match": "//.*$" },
        { "name": "comment.block.cm", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.cm", "match": "\\b(if|else|while|for|return|match|break|continue)\\b" },
        { "name": "keyword.declaration.cm", "match": "\\b(fn|let|mut|struct|impl|class|new|require)\\b" },
        { "name": "keyword.operator.cm", "match": "(&&|\\|\\||==|!=|<=|>=|<|>|\\+|-|\\*|/|=|!|=>)" }
      ]
    },
    "types": {
      "patterns": [
        { "name": "storage.type.cm", "match": "\\b(string|str|ptr|list|array|map|int|float|bool|void|char)\\b" },
        { "name": "entity.name.type.cm", "match": "\\b[A-Z][a-zA-Z0-9_]*\\b" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.cm",
          "begin": "\"",
          "end": "\"",
          "patterns": [ { "name": "constant.character.escape.cm", "match": "\\\\." } ]
        },
        {
          "name": "string.quoted.single.cm",
          "begin": "'",
          "end": "'",
          "patterns": [ { "name": "constant.character.escape.cm", "match": "\\\\." } ]
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.cm",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": { "1": { "name": "entity.name.function.cm" } }
        }
      ]
    },
    "variables": {
      "patterns": [
        { "name": "variable.language.self.cm", "match": "\\b(self)\\b" },
        { "name": "variable.other.cm", "match": "\\b[a-z_][a-zA-Z0-9_]*\\b" }
      ]
    }
  },
  "scopeName": "source.cm"
}
